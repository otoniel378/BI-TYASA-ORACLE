# ============================================================================
# TYASA BI — Plantilla de secrets.toml  (Oracle ADW)
# ============================================================================
# 1. Copia este archivo como:  .streamlit/secrets.toml
# 2. Rellena los valores reales
# 3. NUNCA subas secrets.toml a git — ya está en .gitignore
# ============================================================================

# ── API de Google AI (Gemini) ────────────────────────────────────────────────
GEMINI_API_KEY = "AIzaSy..."

# ── Oracle Autonomous Data Warehouse ────────────────────────────────────────
# Descarga el wallet desde OCI Console:
#   Oracle Database → Tu ADW → DB Connection → Download Wallet
# Descomprime el wallet en una carpeta local (ej. C:/oracle/wallet_TYASA)
[oracle]
user             = "ADMIN"
password         = "TuPassword123!"

# Nombre del servicio TNS — opciones típicas del ADW:
#   tyasaadw_high  (mayor paralelismo, recomendado para reportes)
#   tyasaadw_medium
#   tyasaadw_low
dsn              = "tyasaadw_high"

# Carpeta donde descomprimiste el wallet (contiene tnsnames.ora, sqlnet.ora, etc.)
wallet_dir       = "C:/oracle/wallet_TYASA"
wallet_password  = "TuWalletPassword123!"
