# ============================================================================
# TYASA BI — Variables de entorno para scripts ETL
# ============================================================================
# 1. Copia este archivo como: .env
# 2. Rellena los valores reales
# 3. NUNCA subas .env a git — ya está en .gitignore
#
# Estos valores son para los scripts de scripts/ que corren fuera de Streamlit.
# La app de Streamlit usa .streamlit/secrets.toml en su lugar.
# ============================================================================

ORACLE_USER=ADMIN
ORACLE_PASSWORD=TuPassword123!
ORACLE_DSN=tyasaadw_high

# Carpeta donde descomprimiste el wallet de Oracle ADW
# (contiene tnsnames.ora, sqlnet.ora, cwallet.sso, etc.)
ORACLE_WALLET_DIR=C:/oracle/wallet_TYASA
ORACLE_WALLET_PASSWORD=TuWalletPassword123!
